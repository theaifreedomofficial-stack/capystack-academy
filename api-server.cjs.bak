const express = require('express');
const cors = require('cors');
require('dotenv').config();
const Stripe = require('stripe');
const stripe = new Stripe(process.env.STRIPE_SECRET_KEY, { apiVersion: '2024-11-20.acacia' });
const app = express();
app.use(cors());
app.use(express.json());
app.get('/api/health', (req, res) => res.json({ status: 'ok' }));
app.post('/api/stripe/create-checkout-session', async (req, res) => {
  const { planName, priceAmount, billingPeriod } = req.body;
  try {
    const session = await stripe.checkout.sessions.create({
      payment_method_types: ['card'], mode: 'subscription',
      line_items: [{ price_data: { currency: 'usd', product_data: { name: planName }, unit_amount: priceAmount * 100, recurring: { interval: billingPeriod === 'yearly' ? 'year' : 'month' } }, quantity: 1 }],
      success_url: process.env.APP_URL + '?payment=success',
      cancel_url: process.env.APP_URL + '?payment=cancelled'
    });
    res.json({ simulated: false, checkoutUrl: session.url });
  } catch (err) { res.json({ simulated: true, checkoutUrl: '', error: err.message }); }
});
app.listen(3005, () => console.log('API on 3002'));

const Anthropic = require('@anthropic-ai/sdk');
const anthropic = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });

app.post('/api/analyze-competitor', async (req, res) => {
  const { urlOrTopic, industry } = req.body;
  try {
    const msg = await anthropic.messages.create({
      model: 'claude-sonnet-4-6',
      max_tokens: 1024,
      messages: [{ role: 'user', content: `You are a GEO/SEO competitor analyst. Analyze this competitor: "${urlOrTopic}" in the "${industry}" industry. Return ONLY valid JSON with this exact shape: {"competitor":"string","industry":"string","seoScore":number,"geoScore":number,"aiCitations":["string"],"keywordGaps":["string"],"geoOpportunities":[{"topic":"string","priority":"High|Medium|Low","strategy":"string"}],"recommendations":["string"]}` }]
    });
    res.json(JSON.parse(msg.content[0].text));
  } catch (err) { res.status(500).json({ error: err.message }); }
});

app.post('/api/score-geo-seo', async (req, res) => {
  const { url, industry } = req.body;
  try {
    const msg = await anthropic.messages.create({
      model: 'claude-sonnet-4-6',
      max_tokens: 1024,
      messages: [{ role: 'user', content: `You are a GEO/SEO scoring expert. Score this website: "${url}" in the "${industry}" industry. Return ONLY valid JSON: {"url":"string","seoScore":number,"geoScore":number,"strengths":["string"],"weaknesses":["string"],"recommendations":["string"]}` }]
    });
    res.json(JSON.parse(msg.content[0].text));
  } catch (err) { res.status(500).json({ error: err.message }); }
});

app.post('/api/repurpose-content', async (req, res) => {
  const { content, formats } = req.body;
  try {
    const msg = await anthropic.messages.create({
      model: 'claude-sonnet-4-6',
      max_tokens: 1024,
      messages: [{ role: 'user', content: `Repurpose this content into multiple formats: "${content}". Formats requested: ${JSON.stringify(formats)}. Return ONLY valid JSON: {"original":"string","repurposed":[{"format":"string","content":"string"}]}` }]
    });
    res.json(JSON.parse(msg.content[0].text));
  } catch (err) { res.status(500).json({ error: err.message }); }
});
